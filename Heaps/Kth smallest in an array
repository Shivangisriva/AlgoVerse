class Solution {
    public int kthSmallest(int[] nums, int k) {

        PriorityQueue<Integer> pq =
            new PriorityQueue<>(Collections.reverseOrder());

        for(int num : nums) {

            pq.add(num);

            if(pq.size() > k)
                pq.poll();
        }

        return pq.peek();
    }
}
