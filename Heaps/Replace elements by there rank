import java.util.*;

class Solution {
    static void replaceWithRank(int arr[]) {

        int n = arr.length;

        int res[][] = new int[n][2];

        for(int i = 0; i < n; i++) {
            res[i][0] = arr[i];
            res[i][1] = i;
        }

        Arrays.sort(res, (a, b) -> Integer.compare(a[0], b[0]));

        int ans[] = new int[n];

        for(int i = 0; i < n; i++) {
            ans[res[i][1]] = i;
        }

        
    }
}
