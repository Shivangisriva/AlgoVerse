/**
 * Definition for a binary tree node.
 * public class TreeNode {
 *     int val;
 *     TreeNode left;
 *     TreeNode right;
 *     TreeNode() {}
 *     TreeNode(int val) { this.val = val; }
 *     TreeNode(int val, TreeNode left, TreeNode right) {
 *         this.val = val;
 *         this.left = left;
 *         this.right = right;
 *     }
 * }
 */
class Solution {
    public List<Integer> postorderTraversal(TreeNode root) {
        List<Integer> res = new ArrayList<>();
        Stack<TreeNode> st =  new Stack<>();
        TreeNode curr = root;
        TreeNode lastvisited = null;
        while(!st.isEmpty() || curr!=null)
        {
            if(curr!=null)
            {
            st.push(curr);
            curr = curr.left;
            }
            else
            {
              TreeNode lastpeek = st.peek();
              if(lastpeek.right!=null && lastpeek.right!= lastvisited)
              curr = lastpeek.right;

              else 
              {
                res.add(lastpeek.val);
               lastvisited = st.pop();   
                          }
            }
        }
        return res;
    }
}
