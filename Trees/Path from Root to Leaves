/*

Definition for Binary Tree Node
class Node
{
    int data;
    Node left;
    Node right;

    Node(int data)
    {
        this.data = data;
        left = null;
        right = null;
    }
}
*/

class Solution {
           
    public static ArrayList<ArrayList<Integer>> Paths(Node root) {
        // code here
        ArrayList<ArrayList<Integer>> res = new ArrayList<>();
        ArrayList<Integer> list = new ArrayList<>();
        
        if(root == null)
        return res;
        
        dfs(list , res , root);
        
        return res;
        
    }
  static void dfs(ArrayList<Integer> list ,ArrayList<ArrayList<Integer>> res , Node root)
    {
        if(root == null)
        {
            return;
        }
        list.add(root.data);
        if(root.left == null && root.right == null)
        {
            res.add(new ArrayList<>(list));
        }
        if(root.left != null)
       {
           dfs(list ,res , root.left);
       }
       if(root.right!= null)
       {
           dfs(list ,res , root.right);
       }
       list.remove(list.size()-1);
    }
}



