/*Complete the function below
Node is as follows:
class Node{
    int data;
    Node left,right;
    Node(int d){
        data=d;
        left=right=null;
    }
}
*/
class Solution {
    // returns the inorder successor of the Node x in BST (rooted at 'root')
    public int inorderSuccessor(Node root, Node x) {
        // add code here.
        Node succ = null;
        int target = x.data;
        
        while(root!=null)
        {
            
            if(target >= root.data)
          root = root.right;
            else
            {
                succ = root;
                root = root.left;
            }
        }
            return (succ == null)? -1: succ.data;
        }
    }
    
