class Solution {
    class Pair
    {
        int val;
        Node node;
        Pair( Node node , int val)
        {
            this.val = val;
            this.node = node;
        }
    }
    public ArrayList<Integer> bottomView(Node root) {
        // code here
        ArrayList<Integer> res = new ArrayList<>();
        TreeMap<Integer, Integer> map = new TreeMap<>();
        Queue<Pair> q = new LinkedList<>();
q.add(new Pair(root, 0));
        
        while(!q.isEmpty())
        {
            Pair it = q.remove();
            int data = it.val;
            Node nn = it.node;
          // LATEST NODE OVERRIDES THE PREV NODE
            map.put(data , nn.data);
           
            
            if(nn.left!= null)
            q.add(new Pair(nn.left , data-1));
            
            if(nn.right!=null)
            q.add(new Pair(nn.right , data+1));
            
        }
        for(Map.Entry<Integer , Integer> entry: map.entrySet())
        {
            res.add(entry.getValue());
        }
        return res;
    }
}
