class Solution {

    static void mapParents(Node root, Map<Node, Node> parentMap) {
        Queue<Node> q = new LinkedList<>();
        q.offer(root);

        while (!q.isEmpty()) {
            Node curr = q.poll();

            if (curr.left != null) {
                parentMap.put(curr.left, curr);
                q.offer(curr.left);
            }

            if (curr.right != null) {
                parentMap.put(curr.right, curr);
                q.offer(curr.right);
            }
        }
    }

    // ✅ Helper to find target node using BFS
    static Node findTarget(Node root, int target) {
        Queue<Node> q = new LinkedList<>();
        q.offer(root);

        while (!q.isEmpty()) {
            Node curr = q.poll();
            if (curr.data == target) return curr;

            if (curr.left != null) q.offer(curr.left);
            if (curr.right != null) q.offer(curr.right);
        }
        return null;
    }

    public int minTime(Node root, int target) {
        Map<Node, Node> parentMap = new HashMap<>();
        mapParents(root, parentMap);

        Node targetNode = findTarget(root, target); // ✅ get Node object of target

        Map<Node, Boolean> visited = new HashMap<>();
        Queue<Node> q = new LinkedList<>();

        q.offer(targetNode); // ✅ now Node passed
        visited.put(targetNode, true);

        int time = 0;

        while (!q.isEmpty()) {
            int size = q.size();
            boolean burnedNewNode = false;

            for (int i = 0; i < size; i++) {
                Node curr = q.poll();

                if (curr.left != null && visited.get(curr.left) == null) {
                    visited.put(curr.left, true);
                    q.offer(curr.left);
                    burnedNewNode = true;
                }

                if (curr.right != null && !visited.containsKey(curr.right)) {
                    visited.put(curr.right, true);
                    q.offer(curr.right);
                    burnedNewNode = true;
                }

                if (parentMap.containsKey(curr) && !visited.containsKey(parentMap.get(curr))) {
                    visited.put(parentMap.get(curr), true);
                    q.offer(parentMap.get(curr));
                    burnedNewNode = true;
                }
            }

            if (burnedNewNode) time++;
        }

        return time;
    }
}
