/**
 * Definition for a binary tree node.
 * public class TreeNode {
 *     int val;
 *     TreeNode left;
 *     TreeNode right;
 *     TreeNode() {}
 *     TreeNode(int val) { this.val = val; }
 *     TreeNode(int val, TreeNode left, TreeNode right) {
 *         this.val = val;
 *         this.left = left;
 *         this.right = right;
 *     }
 * }
 */
class Solution {
    public TreeNode buildTree(int[] inorder, int[] postorder) {
        HashMap<Integer, Integer> map = new HashMap<>();
        int n = inorder.length;
        for(int i = 0 ; i<n;i++)
        {
            map.put(inorder[i] , i);
        }
        return findTree(inorder , 0 , n-1 , postorder , 0 , n-1 , map);
    }
    TreeNode findTree(int[]inorder , int inStart , int inEnd , int[] postorder
    , int postStart , int postEnd , HashMap<Integer, Integer> map)
    {
        if(inStart> inEnd || postStart> postEnd)
        return null;

        TreeNode root = new TreeNode(postorder[postEnd]);
        
        int inRoot = map.get(root.val);
        int numsLeft = inRoot - inStart;

        root.left = findTree(inorder ,inStart  , inRoot -1 ,postorder 
        , postStart , postStart+numsLeft-1, map);
        root.right = findTree(inorder , inRoot +1 , inEnd
        , postorder ,postStart+numsLeft, postEnd-1, map);

        return root;
    }
}
